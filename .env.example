# Copy to .env and override as needed. The defaults in docker-compose.yml let it
# run without a .env, but you MUST set a real AUTHENTIK_SECRET_KEY before any
# non-throwaway use. .env is gitignored; this .env.example is committed.

# --- PostgreSQL ---
POSTGRES_USER=vaultlog
POSTGRES_PASSWORD=vaultlog
POSTGRES_DB=vaultlog
AUTHENTIK_POSTGRES_PASSWORD=authentik

# --- Authentik ---
# Generate with: openssl rand -base64 60
AUTHENTIK_SECRET_KEY=
AUTHENTIK_TAG=2026.5.2

# -----------------------------------------------------------------------------
# The .NET app runs on the host (not in compose). Configure it via
# dotnet user-secrets / env vars, pointing at the ports above:
#
#   ConnectionStrings__Postgres = Host=localhost;Port=5433;Database=vaultlog;Username=vaultlog;Password=vaultlog
#   Redis__ConnectionString     = localhost:6379,defaultDatabase=1
#   Authentik__Authority        = http://localhost:9000/application/o/<app-slug>/
#   Tmdb__ApiKey                = <from themoviedb.org>
#   Igdb__ClientId              = <from dev.twitch.tv>
#   Igdb__ClientSecret          = <from dev.twitch.tv>
# -----------------------------------------------------------------------------
